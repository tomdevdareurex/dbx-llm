# Copy this file to .env and fill in your auth method.
#   cp .env.example .env
#
# Pick ONE of the two auth methods below.

# A) Recommended: use a named profile from ~/.databrickscfg
#    Create it once with:  databricks auth login
DATABRICKS_CONFIG_PROFILE=DEFAULT

# B) Or provide host + token directly (overrides the profile above)
# DATABRICKS_HOST=https://<your-workspace>.databricks.com
# DATABRICKS_TOKEN=dapi...

# Optional: point at a custom prompts directory (defaults to ./prompts)
# DBX_LLM_PROMPT_DIR=./prompts
